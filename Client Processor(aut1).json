      "parameters": {
        "html": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\">\n<style>\nbody { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #f5f7fa; margin: 0; padding: 40px; }\n.container { max-width: 900px; margin: 0 auto; background: white; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); overflow: hidden; }\n.header { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 40px; text-align: center; }\n.header h1 { margin: 0; font-size: 32px; font-weight: 600; }\n.header p { margin: 10px 0 0; opacity: 0.9; font-size: 16px; }\n.kpi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; padding: 30px; }\n.kpi-card { background: #f8f9fa; border-radius: 8px; padding: 20px; border-left: 4px solid #667eea; }\n.kpi-card h3 { margin: 0 0 8px; font-size: 14px; color: #6c757d; text-transform: uppercase; font-weight: 500; }\n.kpi-card .value { font-size: 28px; font-weight: 700; color: #212529; margin: 0; }\n.kpi-card .change { font-size: 14px; color: #28a745; margin-top: 8px; }\n.section { padding: 30px; border-top: 1px solid #e9ecef; }\n.section h2 { margin: 0 0 20px; font-size: 24px; color: #212529; }\n.ai-content { line-height: 1.8; color: #495057; white-space: pre-wrap; }\n.footer { background: #f8f9fa; padding: 20px; text-align: center; color: #6c757d; font-size: 14px; }\n</style>\n</head>\n<body>\n<div class=\"container\">\n<div class=\"header\">\n<h1>Weekly Marketing Performance Report</h1>\n<p>{{ $json.client_name }} | {{ $json.week_start }} to {{ $json.week_end }}</p>\n</div>\n<div class=\"kpi-grid\">\n<div class=\"kpi-card\">\n<h3>Ad Spend</h3>\n<p class=\"value\">${{ $json.ad_spend.toLocaleString() }}</p>\n</div>\n<div class=\"kpi-card\">\n<h3>Revenue</h3>\n<p class=\"value\">${{ $json.revenue.toLocaleString() }}</p>\n<p class=\"change\">+{{ $json.growth_percentage }}% vs last week</p>\n</div>\n<div class=\"kpi-card\">\n<h3>ROAS</h3>\n<p class=\"value\">{{ $json.roas }}x</p>\n</div>\n<div class=\"kpi-card\">\n<h3>Purchases</h3>\n<p class=\"value\">{{ $json.purchases }}</p>\n</div>\n<div class=\"kpi-card\">\n<h3>Conversion Rate</h3>\n<p class=\"value\">{{ $json.conversion_rate }}%</p>\n</div>\n<div class=\"kpi-card\">\n<h3>Cost Per Lead</h3>\n<p class=\"value\">${{ $json.cost_per_lead }}</p>\n</div>\n</div>\n<div class=\"section\">\n<h2>Top Performers</h2>\n<p><strong>Best Campaign:</strong> {{ $json.top_campaign }}</p>\n<p><strong>Best Product:</strong> {{ $json.best_product }}</p>\n</div>\n<div class=\"section\">\n<h2>AI Executive Analysis</h2>\n<div class=\"ai-content\">{{ $json.ai_report }}</div>\n</div>\n<div class=\"footer\">\nGenerated automatically by n8n | {{ $now.toFormat(\"MMMM d, yyyy 'at' h:mm a\") }}\n</div>\n</div>\n</body>\n</html>"
      },
