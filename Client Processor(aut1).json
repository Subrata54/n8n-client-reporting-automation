        "jsCode": "const now = new Date();\nconst data = $json;\n\nconsole.log(`[${now.toISOString()}] Validate Data - START - Client: ${data.client_name}`);\n\nconst errors = [];\n\nif (data.revenue === undefined || data.revenue === null) {\n  errors.push(\"Revenue is missing\");\n}\n\nif (data.roas === undefined || data.roas === null) {\n  errors.push(\"ROAS is missing\");\n}\n\nif (data.ad_spend === undefined || data.ad_spend === null) {\n  errors.push(\"Ad Spend is missing\");\n}\n\nif (data.client_name === undefined || data.client_name === null || data.client_name === \"\") {\n  errors.push(\"Client name is missing\");\n}\n\nif (errors.length > 0) {\n  console.error(`[${now.toISOString()}] Validate Data - FAILED - ${errors.join(\", \")}`);\n  throw new Error(`Data validation failed: ${errors.join(\", \")}`);\n}\n\nconsole.log(`[${now.toISOString()}] Validate Data - SUCCESS - All required fields present`);\n\nreturn [{ json: data }];"
      },
