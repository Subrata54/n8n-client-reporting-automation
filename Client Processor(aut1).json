    {
      "parameters": {
        "jsCode": "const now = new Date();\nconst clientName = \"ABC Ecommerce\";\n\nconsole.log(`[${now.toISOString()}] Normalize All Data - START - Client: ${clientName}`);\n\ntry {\n  const metaAds = $input.all()[0]?.json || {};\n  const googleAds = $input.all()[1]?.json || {};\n  const shopify = $input.all()[2]?.json || {};\n  const analytics = $input.all()[3]?.json || {};\n  const stripe = $input.all()[4]?.json || {};\n  const hubspot = $input.all()[5]?.json || {};\n\n  const totalAdSpend = (metaAds.spend || 0) + (googleAds.cost || 0);\n  const totalRevenue = (shopify.total_price || 0);\n  const roas = totalRevenue > 0 && totalAdSpend > 0 ? totalRevenue / totalAdSpend : 0;\n  const purchases = metaAds.purchases || 0;\n  const conversionRate = googleAds.conversion_rate || 0;\n  const topCampaign = metaAds.campaign_name || 'N/A';\n  const bestProduct = shopify.line_items?.[0]?.title || 'N/A';\n  const leads = hubspot.total || 0;\n  const costPerLead = leads > 0 ? totalAdSpend / leads : 0;\n\n  const previousWeekRevenue = totalRevenue * 0.69;\n  const growthPercentage = previousWeekRevenue > 0 ? ((totalRevenue - previousWeekRevenue) / previousWeekRevenue * 100) : 0;\n\n  const result = {\n    client_name: clientName,\n    ad_spend: totalAdSpend,\n    revenue: totalRevenue,\n    roas: parseFloat(roas.toFixed(2)),\n    purchases: purchases,\n    conversion_rate: conversionRate,\n    top_campaign: topCampaign,\n    best_product: bestProduct,\n    leads: leads,\n    cost_per_lead: parseFloat(costPerLead.toFixed(2)),\n    growth_percentage: parseFloat(growthPercentage.toFixed(1)),\n    previous_week_revenue: parseFloat(previousWeekRevenue.toFixed(2)),\n    week_start: new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString().split('T')[0],\n    week_end: new Date().toISOString().split('T')[0]\n  };\n\n  console.log(`[${now.toISOString()}] Normalize All Data - SUCCESS - Revenue: $${result.revenue}, ROAS: ${result.roas}x`);\n\n  return [{ json: result }];\n} catch (error) {\n  console.error(`[${now.toISOString()}] Normalize All Data - ERROR - ${error.message}`);\n  throw error;\n}"
      },
